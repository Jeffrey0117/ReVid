{
  "name": "revid",
  "version": "0.3.0",
  "description": "ReVid - Video viewer and spatial crop tool",
  "author": "Jeffrey0117",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently -k \"cross-env BROWSER=none npm run dev\" \"wait-on http://localhost:3001 && node electron/start.cjs\"",
    "electron:build": "vite build && electron-builder",
    "release": "vite build && electron-builder --publish always",
    "preview": "vite preview"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "^5.3.0",
    "plyr": "^3.7.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^31.7.7",
    "electron-builder": "^26.0.12",
    "tailwindcss": "^4.1.18",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.revid.app",
    "productName": "ReVid",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Jeffrey0117",
        "repo": "ReVid",
        "releaseType": "release"
      }
    ],
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**"
    ],
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "fileAssociations": [
      {
        "ext": "revid",
        "name": "ReVid Collection",
        "description": "ReVid Collection File",
        "role": "Viewer",
        "icon": "revid.png"
      },
      {
        "ext": [
          "mp4",
          "webm",
          "mov",
          "avi",
          "mkv"
        ],
        "name": "Video",
        "description": "Video File",
        "role": "Viewer",
        "icon": "revid.png"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "revid.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  }
}
